# =========================================================================
# RouteLog - Ambiente de Variáveis de Exemplo (Ambiente de Produção)
# Copie este arquivo para um arquivo chamado '.env' e configure as chaves.
# =========================================================================

# --- BACKEND SECRET CHAVES (Acessado apenas no servidor Express) ---
# Chave da API do Google Gemini (Usado para o assistente de inteligência de rotas)
GEMINI_API_KEY=sua_gemini_api_key_aqui

# URL da Hospedagem do Applet (Opcional, preenchido automaticamente)
APP_URL=https://sua-app-url.run.app

# --- FRONTEND PUBLIC CHAVES (Prefixo VITE_ para leitura pelo React/Vite) ---
# Configurações do Firebase SDK no Cliente
VITE_FIREBASE_API_KEY=sua_firebase_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id
VITE_FIREBASE_APP_ID=seu_app_id
VITE_FIREBASE_DATABASE_ID=nome_do_banco_de_dados_se_houver
