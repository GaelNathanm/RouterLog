rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    
    // Checks if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user document exists in the users collection
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Retrieves user profile document from the database
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Validates if the user's role integer matches the requested role
    function isRole(roleNum) {
      return isSignedIn() && hasUserDoc() && getUserData().role == roleNum;
    }

    // Roles based on schema: 0 = Admin, 1 = Gerente, 2 = Motorista, 3 = Vendedor
    function isAdmin() {
      return isSignedIn() && isRole(0);
    }

    function isGerente() {
      return isSignedIn() && isRole(1);
    }

    function isMotorista() {
      return isSignedIn() && isRole(2);
    }

    function isVendedor() {
      return isSignedIn() && isRole(3);
    }

    // Verifies if the user has access to a specific region.
    // Admins have access to all regions.
    // For other roles, access is restricted if they have an assigned region.
    function hasRegionAccess(region) {
      return isSignedIn() && (
        isAdmin() || (
          hasUserDoc() && (
            getUserData().region == region || 
            getUserData().region == "" || 
            getUserData().region == null ||
            region == "" ||
            region == null
          )
        )
      );
    }

    // ==========================================
    // DEFAULT DENY RULE (Global Safety Net)
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Read access is allowed to all signed-in corporate users (e.g., to list drivers or admins)
      allow read: if isSignedIn();
      
      // Creating or updating a user profile is restricted to the owner themselves or an administrator
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Deleting users is restricted to Admins
      allow delete: if isAdmin();
    }

    // ==========================================
    // ROUTES (ROTAS) COLLECTION
    // ==========================================
    match /rotas/{rotaId} {
      // Note: In Firestore, 'Rules are not filters'. Since the client-side application queries collections globally
      // (without regional query parameters), read permissions are granted to all signed-in users to avoid query rejection,
      // while write operations (create, update, delete) are strictly validated by role and regional scope.
      allow read: if isSignedIn();
      
      // Creating route assignments is restricted to Gerentes or Admins who have access to the target region
      allow create: if isSignedIn() && 
                    (isAdmin() || isGerente()) && 
                    hasRegionAccess(request.resource.data.region);
      
      // Updating routes is allowed for Admins, Gerentes of the same region, or the assigned driver
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isGerente() && hasRegionAccess(resource.data.region)) ||
        (isMotorista() && resource.data.driverId == request.auth.uid)
      );
      
      // Only Admins or Gerentes can delete routes within their regions
      allow delete: if isSignedIn() && (isAdmin() || (isGerente() && hasRegionAccess(resource.data.region)));
    }

    // ==========================================
    // GPS LOCATIONS (TELEMETRY)
    // ==========================================
    match /locations/{driverId} {
      // Locations are readable by authorized users
      allow read: if isSignedIn();
      
      // Only the specific driver themselves or central system/managers can write telemetry
      allow write: if isSignedIn() && (request.auth.uid == driverId || isAdmin() || isGerente());
    }

    // ==========================================
    // BREADCRUMBS (COORDINATES HISTORICAL PATH)
    // ==========================================
    match /breadcrumbs/{driverId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == driverId || isAdmin() || isGerente());
    }

    // ==========================================
    // CHATS COLLECTION (OPERATIONAL COLLABORATION)
    // ==========================================
    match /chats/{chatId} {
      // Allowed for all signed-in users (filtering handled by client-side region rules)
      allow read: if isSignedIn();
      
      // Users can write chat messages if they have regional clearance
      allow create: if isSignedIn() && hasRegionAccess(request.resource.data.region);
      
      // Message modifications are reserved for Admins/Gerentes with regional authority
      allow update, delete: if isSignedIn() && (isAdmin() || (isGerente() && hasRegionAccess(resource.data.region)));
    }

    // ==========================================
    // NOTIFICATIONS
    // ==========================================
    match /notifications/{notificationId} {
      // Allowed for all signed-in users (filtering handled by client-side region rules)
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGerente());
    }

    // ==========================================
    // PUSH NOTIFICATION DISPATCH LOGS
    // ==========================================
    match /push_logs/{pushLogId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGerente());
    }

    // ==========================================
    // ADMINISTRATIVE AUDIT LOGS
    // ==========================================
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing audit logs for operational tracking of actions
    }

    // ==========================================
    // PERFORMANCE LOGS (DELIVERY EFFICIENCY)
    // ==========================================
    match /performance_logs/{performanceLogId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGerente() || isMotorista());
    }

    // ==========================================
    // REGIONS
    // ==========================================
    match /regions/{regionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isGerente());
    }

    // ==========================================
    // CLIENTS
    // ==========================================
    match /clients/{clientId} {
      allow read: if isSignedIn();
      
      // Creating and updating clients is restricted to Sales representatives (Vendedor), Managers, and Admins
      allow create, update: if isSignedIn() && 
                            (isAdmin() || isGerente() || isVendedor()) && 
                            hasRegionAccess(request.resource.data.region);
      
      // Deletion is restricted to Admins and Gerentes
      allow delete: if isSignedIn() && (isAdmin() || (isGerente() && hasRegionAccess(resource.data.region)));
    }
  }
}
