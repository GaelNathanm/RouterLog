rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar: Verifica se o usuário está autenticado
    function isAuthed() {
      return request.auth != null;
    }

    // Função auxiliar: Busca o perfil do usuário logado no banco de dados
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Função auxiliar: Verifica se o usuário é Administrador
    function isAdmin() {
      return isAuthed() && (
        getUserData().role == 0 || 
        getUserData().role == '0' || 
        getUserData().role == 'Admin'
      );
    }

    // Função auxiliar: Verifica se o usuário é Gerente
    function isGerente() {
      return isAuthed() && (
        getUserData().role == 1 || 
        getUserData().role == '1' || 
        getUserData().role == 'Gerente'
      );
    }

    // Regras para a Coleção de Usuários
    match /users/{userId} {
      allow read, write: if isAuthed();
    }

    // Regras para a Coleção de Regiões
    match /regions/{regionId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (isAdmin() || isGerente());
    }

    // Regras para a Coleção de Rotas
    match /rotas/{rotaId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para Auditoria e Logs (Imutabilidade total)
    match /audit_logs/{logId} {
      allow read: if isAuthed() && isAdmin();
      allow create: if isAuthed(); // Qualquer ação do sistema pode gerar um log
      allow update, delete: if false; // NINGUÉM pode alterar ou deletar logs históricos
    }

    // Regras para Localização em Tempo Real
    match /locations/{locationId} {
      allow read: if isAuthed();
      // O motorista só pode atualizar a sua própria localização, ou Admin
      allow write: if isAuthed() && (request.auth.uid == locationId || isAdmin());
    }

    // Regras para o Canal de Chat
    match /chats/{chatId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para Notificações e Alertas
    match /notifications/{notificationId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para Logs de Envio Push
    match /push_logs/{pushLogId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para Relatórios de Performance
    match /performance_logs/{performanceLogId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para Trilhas de Navegação (Breadcrumbs)
    match /breadcrumbs/{breadcrumbId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // Regras para o Banco de Clientes
    match /clients/{clientId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }
  }
}
  